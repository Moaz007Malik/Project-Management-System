# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/promgmt?retryWrites=true&w=majority

# Frontend URL(s) for CORS — comma-separated (REQUIRED on Vercel backend)
FRONTEND_URL=http://localhost:5173
# Production example:
# FRONTEND_URL=https://descon-pjtmgmt.vercel.app
# Multiple (production + preview):
# FRONTEND_URL=https://descon-pjtmgmt.vercel.app,https://descon-pjtmgmt-git-main.vercel.app

# Local dev port (Vercel sets PORT automatically)
PORT=3001

# Set to true on Windows if mongodb+srv DNS fails locally
FORCE_PUBLIC_DNS=false

# Set by Vercel automatically in production
# VERCEL=1
# NODE_ENV=production
